# ============================================================
# nuck001 (LAPTOP-Nuck) OpenClaw Agent — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Anthropic (Claude LLM) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Telegram Bot ---
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_IDS=8407969817

# --- Google OAuth2 ---
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Redirect URI (keep as-is for local OAuth)
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# --- Google Gemini (optional fallback) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenClaw Agent Identity ---
AGENT_NAME=nuck001
AGENT_DISPLAY_NAME=橘貓/右腦

# --- Optional: Model override ---
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6
